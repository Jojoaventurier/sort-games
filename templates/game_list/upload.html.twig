{% extends 'base.html.twig' %}

{% block title %}Upload Collection{% endblock %}

{% block body %}
<div class="max-w-xl mx-auto py-16 px-4">
    <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-xl">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-slate-900">Upload Game List</h1>
            <p class="text-slate-500 text-sm">Upload a .txt file to organize your library.</p>
        </div>

        {{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}
            <div>
                {{ form_label(form.name, 'List Name', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-1'}}) }}
                {{ form_widget(form.name, {'attr': {'class': 'w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition', 'placeholder': 'e.g. Summer RPGs'}}) }}
                <p class="mt-1 text-xs text-red-500">{{ form_errors(form.name) }}</p>
            </div>

            <div>
                {{ form_label(form.file, 'Select TXT File', {'label_attr': {'class': 'block text-sm font-semibold text-slate-700 mb-1'}}) }}
                <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-300 border-dashed rounded-lg hover:border-indigo-400 transition-colors cursor-pointer relative">
                    <div class="space-y-1 text-center">
                        <svg class="mx-auto h-12 w-12 text-slate-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                            <path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        <div class="flex text-sm text-slate-600">
                             {{ form_widget(form.file, {'attr': {'class': 'cursor-pointer'}}) }}
                        </div>
                    </div>
                </div>
                <p class="mt-1 text-xs text-red-500">{{ form_errors(form.file) }}</p>
            </div>

            <button type="submit" class="w-full py-3 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-100 transition-all transform active:scale-[0.98]">
                Start Processing
            </button>
        {{ form_end(form) }}

        {% for message in app.flashes('success') %}
            <div class="mt-6 p-4 bg-emerald-50 border border-emerald-100 text-emerald-700 rounded-lg text-sm font-medium flex items-center gap-2">
                <span>✅</span> {{ message }}
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}