{% extends 'base.html.twig' %}

{% block title %}My Collections{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto py-10 px-4">
    <div class="flex justify-between items-center mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Uploaded Collections</h1>
        <a href="{{ path('game_list_upload') }}" class="px-4 py-2 bg-indigo-600 text-white text-sm font-semibold rounded-lg hover:bg-indigo-700 transition shadow-sm">
            + New List
        </a>
    </div>

    <div class="grid gap-4">
        {% for list in lists %}
            <div class="group bg-white border border-slate-200 p-5 rounded-xl hover:border-indigo-300 hover:shadow-md transition-all">
                <div class="flex justify-between items-center">
                    <div>
                        <a href="{{ path('game_list_show', {'id': list.id}) }}" class="text-lg font-semibold text-slate-800 group-hover:text-indigo-600">
                            {{ list.name }}
                        </a>
                        <p class="text-sm text-slate-500 mt-1">
                            {{ list.games|length }} games • {{ list.uploadedAt|date('M d, Y') }}
                        </p>
                    </div>
                    <span class="text-slate-300 group-hover:text-indigo-400 transition">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="9 5l7 7-7 7"></path></svg>
                    </span>
                    <form method="post"
                        action="{{ path('game_list_delete', { id: list.id }) }}"
                        onsubmit="return confirm('Delete this list?');">
                        <input type="hidden" name="_token"
                            value="{{ csrf_token('delete_game_list_' ~ list.id) }}">

                        <button class="px-3 py-1 text-sm text-white bg-red-600 rounded hover:bg-red-700">
                            Delete
                        </button>
                    </form>
                </div>
            </div>
        {% else %}
            <div class="text-center py-20 bg-slate-50 rounded-2xl border-2 border-dashed border-slate-200">
                <p class="text-slate-400">No collections found. Start by uploading a TXT file.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}