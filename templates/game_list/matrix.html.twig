{% extends 'base.html.twig' %}

{% block title %}Duplicate Matrix{% endblock %}

{% block body %}
<div class="p-6">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Duplicate Master Matrix</h1>
        <p class="text-slate-500">Cross-referencing the last 6 hard drive scans.</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-xl shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse table-fixed">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="w-64 px-4 py-4 text-xs font-bold uppercase text-slate-600">Game (Normalized)</th>
                        {# Generate the 6 Hard Drive Columns #}
                        {% for list in lists %}
                            <th class="px-4 py-4 text-xs font-bold uppercase text-slate-600 border-l border-slate-200">
                                <div class="truncate" title="{{ list.name }}">{{ list.name }}</div>
                                <div class="text-[10px] text-slate-400 font-normal">{{ list.uploadedAt|date('d/m/y') }}</div>
                            </th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    {% for normName, row in matrix %}
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="px-4 py-3 text-sm font-semibold text-slate-800 bg-slate-50/30">
                                {{ normName }}
                            </td>
                            
                            {% for list in lists %}
                                <td class="px-4 py-3 border-l border-slate-100">
                                    {% if row[list.id] is defined %}
                                        {% set item = row[list.id] %}
                                        <div class="flex flex-col gap-1">
                                            {# Visual Indicator for Duplicate #}
                                            <span class="text-[10px] leading-tight text-red-600 font-mono break-words">
                                                {{ item.name }}
                                            </span>
                                            <div class="flex justify-between items-center">
                                                <span class="text-[9px] px-1 bg-slate-100 rounded text-slate-500">{{ item.tag }}</span>
                                                <span class="text-[9px] font-bold text-slate-400">{{ item.size }}</span>
                                            </div>
                                        </div>
                                    {% else %}
                                        <span class="text-slate-200 text-xs">-</span>
                                    {% endif %}
                                </td>
                            {% endfor %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}