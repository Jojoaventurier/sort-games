{% extends 'base.html.twig' %}

{% block title %}Global Library Overview{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto py-10 px-4">
    <div class="flex flex-col md:flex-row justify-between items-end mb-8 gap-4">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">Global Library</h1>
            <p class="text-slate-500">Newest versions are highlighted. Older versions are listed below for cleanup.</p>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-6">
            {# NEW: Toggle for Duplicates Only #}
            <div class="flex items-center gap-3 bg-slate-100 px-4 py-2 rounded-lg border border-slate-200">
                <label for="duplicateToggle" class="text-sm font-semibold text-slate-700 cursor-pointer">Duplicates Only</label>
                <input type="checkbox" id="duplicateToggle" class="w-4 h-4 text-indigo-600 rounded focus:ring-indigo-500 cursor-pointer">
            </div>

            {# Drive Filter #}
            <div class="flex items-center gap-3">
                <label class="text-sm font-semibold text-slate-700">Filter by Drive:</label>
                <select id="driveFilter" class="rounded-lg border-slate-200 text-sm focus:ring-indigo-500">
                    <option value="all">All Hard Drives</option>
                    {% for list in allLists %}
                        <option value="{{ list.name }}">{{ list.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>

    <div class="space-y-8">
        {% for title, entries in library %}
            {# ADDED: data-count attribute #}
            <div class="game-stack bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm" 
                 data-count="{{ entries|length }}"
                 data-drives="{{ entries|map(e => e.gameList.name)|join(',') }}">
                
                {# ... Group Header ... #}
                <div class="px-6 py-3 bg-slate-50 border-b border-slate-100 flex justify-between items-center">
                    <h2 class="font-bold text-slate-800 uppercase tracking-tight text-sm">{{ title }}</h2>
                    <span class="text-[10px] bg-slate-200 px-2 py-0.5 rounded-full font-bold text-slate-600">
                        {{ entries|length }} VERSIONS
                    </span>
                </div>

                <div class="divide-y divide-slate-100">
                    {% for entry in entries %}
                        {# ... Entry rows (kept exactly the same as yours) ... #}
                        {% set isNewest = loop.first %}
                        <div class="px-6 py-4 flex items-center justify-between transition-colors {{ isNewest ? 'bg-emerald-50/50' : 'bg-white' }}">
                            <div class="flex items-center gap-4">
                                {% if isNewest %}
                                    <span class="flex-shrink-0 w-8 h-8 bg-emerald-500 text-white rounded-full flex items-center justify-center text-xs shadow-sm">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                                    </span>
                                {% else %}
                                    <span class="flex-shrink-0 w-8 h-8 bg-slate-100 text-slate-400 rounded-full flex items-center justify-center text-xs">
                                        {{ loop.index }}
                                    </span>
                                {% endif %}

                                <div>
                                    <div class="text-sm font-medium {{ isNewest ? 'text-emerald-900' : 'text-slate-700' }}">
                                        {{ entry.name }}
                                    </div>
                                    <div class="flex gap-3 mt-1">
                                        <span class="text-[11px] font-bold text-indigo-600 uppercase">{{ entry.gameList.name }}</span>
                                        <span class="text-[11px] text-slate-400">• {{ entry.fileSize }}</span>
                                        <span class="text-[11px] text-slate-400">• {{ entry.fileDate }}</span>
                                    </div>
                                </div>
                            </div>
                            {% if not isNewest %}
                                <button class="text-[10px] font-bold text-red-400 hover:text-red-600 uppercase tracking-widest transition-colors">Mark for Deletion</button>
                            {% else %}
                                <span class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest">Active Version</span>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<script>
const driveFilter = document.getElementById('driveFilter');
const duplicateToggle = document.getElementById('duplicateToggle');
const stacks = document.querySelectorAll('.game-stack');

function applyFilters() {
    const selectedDrive = driveFilter.value;
    const duplicatesOnly = duplicateToggle.checked;

    stacks.forEach(stack => {
        const drives = stack.getAttribute('data-drives').split(',');
        const versionCount = parseInt(stack.getAttribute('data-count'));
        
        // Logic check:
        const driveMatch = (selectedDrive === 'all' || drives.includes(selectedDrive));
        const duplicateMatch = (!duplicatesOnly || versionCount > 1);

        if (driveMatch && duplicateMatch) {
            stack.style.display = 'block';
        } else {
            stack.style.display = 'none';
        }
    });
}

driveFilter.addEventListener('change', applyFilters);
duplicateToggle.addEventListener('change', applyFilters);
</script>
{% endblock %}