{% extends 'base.html.twig' %}

{% block title %}{{ gameList.name }}{% endblock %}

{% block body %}
<div class="max-w-5xl mx-auto py-10 px-4">
    <nav class="mb-6">
        <a href="{{ path('game_list_index') }}" class="text-sm text-slate-500 hover:text-indigo-600 flex items-center gap-1">
            ← Back to collections
        </a>
    </nav>

    <form method="post"
      action="{{ path('game_list_delete', { id: gameList.id }) }}"
      onsubmit="return confirm('Delete this list and all its entries?');"
      class="mb-4">
    <input type="hidden" name="_token"
           value="{{ csrf_token('delete_game_list_' ~ gameList.id) }}">

    <button class="px-4 py-2 text-white bg-red-600 rounded hover:bg-red-700">
        Delete this list
    </button>
</form>


    <div class="bg-white border border-slate-200 rounded-2xl overflow-hidden shadow-sm">
        <div class="px-6 py-5 border-b border-slate-100 bg-slate-50/50">
            <h1 class="text-xl font-bold text-slate-800">{{ gameList.name }}</h1>
        </div>

        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="text-xs uppercase tracking-wider text-slate-500 bg-slate-50/50">
                    <th class="px-6 py-3 font-semibold">Game Name</th>
                    <th class="px-6 py-3 font-semibold text-right">Tag</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                {% for entry in entries %}
                <tr class="hover:bg-slate-50/80 transition-colors">
                    <td class="px-6 py-4 text-slate-700 font-medium">{{ entry.name }}</td>
                    <td class="px-6 py-4 text-right">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-100 text-indigo-700">
                            {{ entry.tag }}
                        </span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="2" class="px-6 py-10 text-center text-slate-400 italic">No games found in this list.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}