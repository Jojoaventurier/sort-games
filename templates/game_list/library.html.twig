{% extends 'base.html.twig' %}

{% block title %}Global Library Overview{% endblock %}

{% block body %}
<div class="max-w-6xl mx-auto py-10 px-4">
    {# Header Section #}
    <div class="flex flex-col md:flex-row justify-between items-end mb-10 gap-4 border-b border-slate-200 pb-6">
        <div>
            <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Global Library</h1>
            <p class="text-slate-500 mt-1">Manage versions and clean up duplicates across all drives.</p>
        </div>

        <div class="flex flex-col md:flex-row items-center gap-4">
            {# Toggle for Duplicates Only #}
            <div class="flex items-center gap-3 bg-white px-3 py-2 rounded-lg border border-slate-200 shadow-sm">
                <input type="checkbox" id="duplicateToggle" class="w-4 h-4 text-indigo-600 rounded border-slate-300 focus:ring-indigo-500 cursor-pointer">
                <label for="duplicateToggle" class="text-sm font-medium text-slate-700 cursor-pointer">Duplicates Only</label>
            </div>

            {# Drive Filter #}
            <div class="flex items-center gap-3">
                <select id="driveFilter" class="rounded-lg border-slate-200 text-sm focus:ring-indigo-500 bg-white shadow-sm">
                    <option value="all">All Hard Drives</option>
                    {% for list in allLists %}
                        <option value="{{ list.name }}">{{ list.name }}</option>
                    {% endfor %}
                </select>
            </div>
        </div>
    </div>

    {# List Container #}
    <div class="flex flex-col">
        {# Table Headings (Visual Only) #}
        <div class="hidden md:flex px-6 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wider">
            <div class="flex-1">Title & Version Info</div>
            <div class="w-48 text-right">Status / Action</div>
        </div>

        <div class="divide-y divide-slate-200">
            {% for title, entries in library %}
                <div class="game-stack" 
                     data-count="{{ entries|length }}"
                     data-drives="{{ entries|map(e => e.gameList.name)|join(',') }}">
                    
                    {# Group Header: Minimal and Sticky #}
                    <div class="sticky top-0 z-10 bg-slate-50/95 backdrop-blur-sm border-y border-slate-200 px-6 py-2 flex justify-between items-center">
                        <h2 class="font-bold text-slate-700 uppercase text-xs tracking-widest">{{ title }}</h2>
                        <span class="text-[10px] text-slate-400 font-medium">
                            {{ entries|length }} {% if entries|length > 1 %}VERSIONS{% else %}VERSION{% endif %}
                        </span>
                    </div>

                    <div class="divide-y divide-slate-100 bg-white">
                        {% for entry in entries %}
                            {% set isNewest = loop.first %}
                            <div class="px-6 py-4 flex items-center justify-between hover:bg-slate-50 transition-colors group">
                                <div class="flex items-center gap-6">
                                    {# Index/Status Icon #}
                                    <div class="flex-shrink-0">
                                        {% if isNewest %}
                                            <div class="w-2 h-2 rounded-full bg-emerald-500 ring-4 ring-emerald-50"></div>
                                        {% else %}
                                            <div class="w-2 h-2 rounded-full bg-slate-300"></div>
                                        {% endif %}
                                    </div>

                                    <div>
                                        <div class="text-sm font-semibold {{ isNewest ? 'text-slate-900' : 'text-slate-600' }}">
                                            {{ entry.name }}
                                        </div>
                                        <div class="flex items-center gap-3 mt-0.5">
                                            <span class="text-[11px] font-bold text-indigo-600 uppercase">{{ entry.gameList.name }}</span>
                                            <span class="text-slate-300">|</span>
                                            <span class="text-[11px] text-slate-500">{{ entry.fileSize }}</span>
                                            <span class="text-slate-300">|</span>
                                            <span class="text-[11px] text-slate-500">{{ entry.fileDate }}</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="flex items-center">
                                    {% if not isNewest %}
                                        <button class="opacity-0 group-hover:opacity-100 transition-opacity text-[10px] font-bold text-red-500 hover:text-red-700 uppercase tracking-widest">
                                            Delete
                                        </button>
                                    {% else %}
                                        <span class="text-[10px] font-bold text-emerald-600 uppercase tracking-widest bg-emerald-50 px-2 py-1 rounded">
                                            Main
                                        </span>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
    const driveFilter = document.getElementById('driveFilter');
    const duplicateToggle = document.getElementById('duplicateToggle');
    const stacks = document.querySelectorAll('.game-stack');

    function applyFilters() {
        const selectedDrive = driveFilter.value;
        const duplicatesOnly = duplicateToggle.checked;

        stacks.forEach(stack => {
            const drives = stack.getAttribute('data-drives').split(',');
            const versionCount = parseInt(stack.getAttribute('data-count'));
            
            const driveMatch = (selectedDrive === 'all' || drives.includes(selectedDrive));
            const duplicateMatch = (!duplicatesOnly || versionCount > 1);

            stack.style.display = (driveMatch && duplicateMatch) ? 'block' : 'none';
        });
    }

    driveFilter.addEventListener('change', applyFilters);
    duplicateToggle.addEventListener('change', applyFilters);
</script>
{% endblock %}