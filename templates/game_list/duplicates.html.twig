{% extends 'base.html.twig' %}

{% block body %}
<div class="max-w-5xl mx-auto py-10 px-4">
    <h1 class="text-3xl font-bold text-slate-900 mb-8">Duplicate Detection</h1>

    <div class="space-y-6">
        {% for normalizedName, occurrences in duplicates %}
            <div class="bg-white border border-red-200 rounded-xl overflow-hidden shadow-sm">
                <div class="bg-red-50 px-6 py-3 border-b border-red-100 flex justify-between items-center">
                    <span class="font-bold text-red-800 uppercase tracking-wide text-sm">
                        Detected Duplicate: {{ normalizedName }}
                    </span>
                    <span class="bg-red-200 text-red-700 px-2 py-1 rounded text-xs font-bold">
                        {{ occurrences|length }} Hits
                    </span>
                </div>

                <div class="p-0">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-xs font-semibold text-slate-500 uppercase bg-slate-50">
                                <th class="px-6 py-3">Original Entry in File</th>
                                <th class="px-6 py-3">Source List</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            {% for occ in occurrences %}
                                <tr class="hover:bg-slate-50 transition">
                                    <td class="px-6 py-4 text-sm font-mono text-slate-600">
                                        {{ occ.original }}
                                    </td>
                                    <td class="px-6 py-4 text-sm">
                                        <a href="{{ path('game_list_show', {id: occ.listId}) }}" class="text-indigo-600 hover:underline">
                                            {{ occ.listName }}
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        {% else %}
            <div class="text-center py-20 bg-green-50 rounded-2xl border-2 border-dashed border-green-200">
                <p class="text-green-600 font-medium">No duplicates found! Your library is clean.</p>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}